# Google OAuth credentials
# Create these at https://console.cloud.google.com/
# Go to APIs & Services > Credentials > Create Credentials > OAuth 2.0 Client ID
#
# Web client (used in browser / Expo Go)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com

# iOS native client (used in iOS development builds and production)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=YOUR_IOS_CLIENT_ID.apps.googleusercontent.com

# Android native client (used in Android development builds and production)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=YOUR_ANDROID_CLIENT_ID.apps.googleusercontent.com
